{
  "env": {
    "_comment": "Env vars injected into agent runtime (skills pick these up)",
    "TAVILY_API_KEY": "${TAVILY_API_KEY}"
  },
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "model": {
        "primary": "rkgw/claude-sonnet-4-6"
      },
      "sandbox": {
        "mode": "off"
      },
      "heartbeat": {
        "_comment": "Heartbeat uses Haiku to save cost; runs during Taipei daytime only",
        "every": "30m",
        "target": "last",
        "model": "rkgw/claude-haiku-4-6",
        "activeHours": {
          "start": "08:00",
          "end": "23:00",
          "timezone": "Asia/Taipei"
        }
      }
    }
  },
  "models": {
    "providers": {
      "rkgw": {
        "_comment": "Models proxied through local rkgw gateway on host",
        "baseUrl": "http://host.docker.internal:8765",
        "api": "anthropic-messages",
        "apiKey": "${ANTHROPIC_API_KEY}",
        "models": [
          {
            "id": "claude-sonnet-4-6",
            "name": "Claude Sonnet 4.6",
            "contextWindow": 200000,
            "maxTokens": 16384
          },
          {
            "id": "claude-opus-4-6",
            "name": "Claude Opus 4.6",
            "contextWindow": 200000,
            "maxTokens": 16384
          },
          {
            "id": "claude-haiku-4-6",
            "name": "Claude Haiku 4.6",
            "contextWindow": 200000,
            "maxTokens": 16384
          }
        ]
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": [6004844659],
      "dmPolicy": "allowlist",
      "ackReaction": "⚡"
    },
    "discord": {
      "enabled": false
    },
    "line": {
      "enabled": false
    }
  },
  "tools": {
    "web": {
      "search": {
        "_comment": "Built-in Brave search disabled; using Tavily skill instead",
        "enabled": false
      }
    }
  },
  "gateway": {
    "port": 18790,
    "bind": "lan",
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "${GATEWAY_TOKEN}"
    },
    "controlUi": {
      "enabled": true,
      "allowedOrigins": ["*"]
    }
  },
  "web": {
    "enabled": true
  },
  "ui": {
    "assistant": { "name": "Claw", "avatar": "⚡" }
  },
  "messages": {
    "ackReactionScope": "all"
  },
  "logging": {
    "level": "debug",
    "consoleStyle": "compact"
  }
}
